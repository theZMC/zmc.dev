---
import "@styles/global.css";
import "@fontsource/marcellus/400.css";
import "@fontsource/cormorant/500-italic.css";
import "@fontsource/instrument-sans/400.css";
import "@fontsource/instrument-sans/500.css";
import "@fontsource/instrument-sans/600.css";
import "@fontsource/instrument-sans/400-italic.css";
import "@fontsource/spline-sans-mono/300.css";
import "@fontsource/spline-sans-mono/400.css";
import Cosmos from "@components/Cosmos.astro";
import Footer from "@components/Footer.astro";
import Nav from "@components/Nav.astro";
import { ClientRouter } from "astro:transitions";

interface Link {
  label: string;
  href: string;
}

interface Props {
  pageTitle: string;
  metaDescription?: string;
  tags?: string[];
  metaImage?: string;
  ogType?: "website" | "article";
  /** ISO 8601 instant — see toIsoTimestamp. Articles only. */
  publishedTime?: string;
  navLinks?: Link[];
  footerLinks?: Link[];
  showProgress?: boolean;
}

// Everything here is Zach's, so the byline is the site's, not a page's.
// LinkedIn resolves article:author as a profile URL and ignores a bare name;
// the human-readable name rides on <meta name="author"> instead.
const AUTHOR_NAME = "Zach Callahan";
const AUTHOR_PROFILE = "https://www.linkedin.com/in/thezmc/";

const {
  pageTitle,
  metaDescription,
  tags,
  // Every page ships a card image — the site plate unless the page brings
  // its own. CI holds the line (scripts/check-social-cards.mjs).
  metaImage = new URL("/og/site.png", Astro.site).toString(),
  ogType = "website",
  publishedTime,
  navLinks,
  footerLinks,
  showProgress,
} = Astro.props;
---

<html lang="en">
  <head>
    <script is:inline>
      // Pin the persisted theme before first paint, and re-pin it after
      // Astro's client-side navigation swaps the <html> attributes back.
      // No stored choice means no attribute: the page stays in auto and
      // color-scheme follows the OS in CSS. js-sky rides along: it hands
      // the sky to site.ts (raw writes + CSS glide) and switches the no-JS
      // scroll-timeline layer off before it ever paints a frame.
      (function () {
        function applyTheme() {
          var stored = null;
          try {
            stored = localStorage.getItem("theme");
          } catch (e) {}
          if (stored === "dark" || stored === "light") {
            document.documentElement.setAttribute("data-theme", stored);
          } else {
            document.documentElement.removeAttribute("data-theme");
          }
          document.documentElement.classList.add("js-sky");
        }
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={metaDescription} />
    <meta name="keywords" content={tags?.join(", ")} />
    <meta name="author" content={AUTHOR_NAME} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@theZMC" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={metaImage} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={Astro.request.url} />
    <meta property="og:image" content={metaImage} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:site_name" content="ZMC.DEV" />
    <meta property="og:locale" content="en_US" />
    {
      ogType === "article" && (
        <>
          <meta property="article:author" content={AUTHOR_PROFILE} />
          {publishedTime && (
            <meta property="article:published_time" content={publishedTime} />
          )}
        </>
      )
    }
    <link
      rel="alternate"
      type="application/rss+xml"
      title="zmc.dev · Transmissions"
      href="/rss.xml"
    />
    <ClientRouter />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <Cosmos />
    <Nav links={navLinks} {showProgress} />
    <main id="content">
      <slot />
    </main>
    <Footer links={footerLinks} />
    <script>
      import "@lib/scripts/site";
    </script>
  </body>
</html>
