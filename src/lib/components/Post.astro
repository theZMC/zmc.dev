---
import { Image } from "astro:assets";
import type { getCollection } from "astro:content";
import DefaultImage from "@images/journalist-on-laptop.png";

interface Props {
  post: Awaited<ReturnType<typeof getCollection<"blog">>>[0];
}

const { post } = Astro.props;
let date = new Date(post.data.date + "T12:00:00").toLocaleDateString(
  "en-US",
  {
    year: "numeric",
    month: "long",
    day: "numeric",
  },
);

if (date === "Invalid Date") {
  date = post.data.date;
}
---

<a href={`/posts/${post.id}`}>
  <article>
    <Image
      src={post.data.cover ? post.data.cover.image : DefaultImage}
      class="w-full h-full object-cover rounded-lg"
      transition:name={`post-cover-${post.id}`}
      alt={post.data.cover
        ? post.data.cover.alt
        : "AI-generated image of journalist on laptop"}
    />
    <header>
      <h2 transition:name={`post-title-${post.id}`}>{post.data.title}</h2>
      <p transition:name={`post-description-${post.id}`}>
        {post.data.description}
      </p>
    </header>
    <footer>
      <div>
        <p>
          <time datetime={date}>
            {date}
          </time>
        </p>
      </div>
      <div>
        {post.data.tags.map((tag: string) => <p>{tag}</p>)}
      </div>
    </footer>
  </article>
</a>

<style>
  a {
    color: inherit;
    text-decoration: none;
  }
  a > article {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
  }
  header {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.5rem;
    background: #00000080;
    color: white;
    backdrop-filter: blur(0.5rem);
    border-top: 1px solid #00000099;
  }
  header > p {
    display: none;
  }
  @media (min-width: 450px) {
    header > p {
      display: block;
    }
  }
  footer {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    padding: 0.25rem;
    background: #00000080;
    color: white;
    backdrop-filter: blur(0.5rem);
  }
  time {
    padding: 0.25rem 0.5rem;
  }
  footer {
    display: flex;
    align-items: center;
    border-bottom: 1px solid #00000099;
  }
  footer > div:last-of-type {
    margin-left: auto;
    display: flex;
    gap: 0.5rem;
    padding: 0.25rem;
  }
  footer > div > p {
    margin: 0;
    padding: 0.25rem 0.5rem;
    font-weight: 300;
    letter-spacing: 0.05rem;
    text-transform: uppercase;
  }
  footer > div:last-of-type > p {
    border-radius: 0.5rem;
    background: #ffffff22;
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 300;
    letter-spacing: 0.05rem;
  }
</style>
