---
import BaseLayout from "@layouts/BaseLayout.astro";
import { byDateDesc, formatPostDate } from "@lib/utils/dates";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(byDateDesc);
---

<BaseLayout pageTitle="Transmissions — Zach Callahan">
  <div class="panel-wrap">
    <section id="transmissions" class="panel tx-panel">
      <div class="sec-head">
        <h2><a href="#transmissions">Transmissions</a></h2>
        <span class="mono coord">Field Notes · Plaintext</span>
      </div>

      {
        posts.map((post) => (
          <a class="tx-row glint-row" href={`/posts/${post.id}`}>
            <h3>{post.data.title}</h3>
            <span class="tx-meta">
              <time class="mono" datetime={post.data.date}>
                {formatPostDate(post.data.date)}
              </time>
              <span class="arrow">→</span>
            </span>
          </a>
        ))
      }
    </section>
  </div>
</BaseLayout>

<style is:global>
  main {
    padding-top: calc(var(--nav-h) + 4.125rem); /* = 8.5rem */
  }

  .tx-panel {
    --head-gap: 2.2rem;
    padding: var(--head-gap) 3rem 2.2rem;
  }

  .tx-row {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    justify-content: space-between;
    padding: 1.7rem var(--row-pad);
    text-decoration: none;
  }
  .tx-row h3 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    transition: color 0.3s;
  }
  .tx-row:hover h3 {
    color: var(--brass);
  }
  .tx-row .tx-meta {
    display: flex;
    align-items: baseline;
    gap: 1.4rem;
    white-space: nowrap;
  }
  .tx-row .arrow {
    color: var(--brass);
    font-family: "Spline Sans Mono", monospace;
  }

  @media (max-width: 860px) {
    main {
      padding-top: calc(var(--nav-h) + 2.125rem); /* = 6.5rem */
    }
    .tx-panel {
      --head-gap: 1.4rem;
      padding: 1.4rem;
    }
  }
</style>
