---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { byDateAsc, formatPostDate, parsePostDate } from "@lib/utils/dates";
import { toRoman } from "@lib/utils/roman";

export const getStaticPaths = async () => {
  const posts = (await getCollection("blog")).sort(byDateAsc);
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: { post, prev: posts[i - 1], next: posts[i + 1] },
  }));
};

const { post, prev, next } = Astro.props;

const date = parsePostDate(post.data.date);
const eyebrow = `Transmission · ${toRoman(date.getFullYear())} · ${String(
  date.getMonth() + 1,
).padStart(2, "0")}`;
const longDate = formatPostDate(post.data.date);

const words = post.body ? post.body.split(/\s+/).filter(Boolean).length : 0;
const readTime = `${Math.max(1, Math.round(words / 200))} min read`;

const metaImage = new URL(`/og/${post.id}.png`, Astro.site).toString();

const { Content } = await render(post);
---

<BaseLayout
  pageTitle={`${post.data.title} — Zach Callahan`}
  metaDescription={post.data.description}
  tags={post.data.tags}
  {metaImage}
  ogType="article"
  showProgress
>
  <div class="panel-wrap">
    <article class="panel post" id="post">
      <div class="post-inner">
        <a class="crumb mono" href="/posts">← All Transmissions</a>

        <div class="post-head">
          <span class="mono eyebrow">{eyebrow}</span>
          <h1>{post.data.title}</h1>
          <div class="post-meta">
            <span class="mono">{longDate}</span>
            <span class="mono">{readTime}</span>
            <div class="tags">
              {
                post.data.tags.map((tag) => (
                  <a class="tag" href={`/posts/by-tag/${tag}`}>
                    {tag}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <div class="post-body">
          <Content />
        </div>

        <p class="end-mark mono">▣ End of Transmission</p>
      </div>
    </article>

    {
      (prev || next) && (
        <div class="post-nav">
          {prev && (
            <a class="panel prev" href={`/posts/${prev.id}`}>
              <span class="dir mono">← Previous</span>
              <h3>{prev.data.title}</h3>
            </a>
          )}
          {next && (
            <a class="panel next" href={`/posts/${next.id}`}>
              <span class="dir mono">Next →</span>
              <h3>{next.data.title}</h3>
            </a>
          )}
        </div>
      )
    }
  </div>
</BaseLayout>

<style is:global>
  main {
    padding-top: calc(var(--nav-h) + 4.125rem); /* = 8.5rem */
  }

  /* ---------- article ---------- */
  .post {
    padding: 4rem 0 3.5rem;
    font-size: 17px;
    line-height: 1.75;
  }
  .post-inner {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .crumb {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 2.6rem;
    transition: color 0.3s;
  }
  .crumb:hover {
    color: var(--brass);
  }

  .post-head .eyebrow {
    color: var(--brass);
    letter-spacing: 0.3em;
    display: block;
    margin-bottom: 1.3rem;
  }
  .post-head h1 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: clamp(1.9rem, 4.4vw, 3rem);
    letter-spacing: 0.06em;
    line-height: 1.22;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 2rem;
    align-items: baseline;
    margin-top: 1.6rem;
    padding-bottom: 2.2rem;
    border-bottom: 1px solid var(--hair);
  }
  .post-meta .tags {
    display: flex;
    gap: 0.45rem;
    margin-left: auto;
  }
  .post-meta .tags a.tag {
    text-decoration: none;
  }
  .post-meta .tags a.tag:hover {
    border-color: var(--celest);
  }

  .post-body {
    padding-top: 2.4rem;
  }
  .post-body p {
    margin-bottom: 1.5rem;
  }
  .post-body > p:first-of-type::first-letter {
    font-family: "Marcellus", serif;
    font-size: 3.4em;
    line-height: 0.85;
    float: left;
    padding: 0.08em 0.12em 0 0;
    color: var(--brass);
  }
  .post-body a {
    color: var(--brass);
    text-decoration: none;
    border-bottom: 1px solid var(--brass-dim);
    transition: border-color 0.3s;
  }
  .post-body a:hover {
    border-color: var(--brass);
  }
  .post-body h2 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    margin: 3rem 0 1.2rem;
    padding-top: 2.2rem;
    border-top: 1px solid var(--hair);
  }
  /* A post that opens with a heading otherwise stacks the meta rule and
     the heading's own top rule around an empty band. */
  .post-body > h2:first-child {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .post-body h3 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.15rem;
    letter-spacing: 0.08em;
    margin: 2.2rem 0 0.9rem;
  }
  .post-body h4 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    margin: 1.8rem 0 0.7rem;
  }
  .post-body h5,
  .post-body h6 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    margin: 1.5rem 0 0.6rem;
  }
  /* rehype-autolink-headings wraps heading text in an anchor link;
     keep it visually indistinguishable from plain heading text. */
  .post-body h2 a.anchor,
  .post-body h3 a.anchor,
  .post-body h4 a.anchor,
  .post-body h5 a.anchor,
  .post-body h6 a.anchor {
    color: inherit;
    text-decoration: none;
    border-bottom: none;
  }
  .post-body h2 a.anchor:hover,
  .post-body h3 a.anchor:hover,
  .post-body h4 a.anchor:hover,
  .post-body h5 a.anchor:hover,
  .post-body h6 a.anchor:hover {
    border-bottom: none;
  }
  .post-body ul {
    margin: 0 0 1.5rem 1.2rem;
  }
  .post-body li {
    margin-bottom: 0.5rem;
  }
  .post-body li::marker {
    color: var(--brass);
  }
  .post-body blockquote {
    margin: 2.2rem 0;
    padding: 0.4rem 0 0.4rem 1.6rem;
    border-left: 1px solid var(--brass);
    font-style: italic;
    color: var(--ink-dim);
  }
  .post-body code {
    font-family: "Spline Sans Mono", monospace;
    font-size: 0.86em;
    background: var(--code-bg);
    border: 1px solid var(--hair);
    border-radius: 5px;
    padding: 0.1em 0.4em;
    /* long identifiers in headings/prose must never pan the page sideways;
       when one must break, clone gives each fragment a complete pill
       instead of shearing the border mid-word */
    overflow-wrap: anywhere;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }
  /* site.ts wraps each pre in a .code-frame and appends the copy button as
     a sibling (a child button pollutes the code's accessible text) */
  .post-body .code-frame {
    position: relative;
    margin: 2rem 0;
  }
  .post-body .code-frame pre {
    margin: 0;
  }
  /* Right-edge fade while a long line continues past the clip edge
     (site.ts toggles data-clipped as the pre scrolls). Two gradient layers
     because --code-bg is translucent glass — --bg underneath lands the fade
     on the block's true composite color. Insets and radius tuck it inside
     the pre's 1px border. */
  .post-body .code-frame::after {
    content: "";
    position: absolute;
    top: 1px;
    bottom: 1px;
    right: 1px;
    width: 3.25rem;
    border-radius: 0 9px 9px 0;
    background:
      linear-gradient(to left, var(--code-bg), transparent),
      linear-gradient(to left, var(--bg), transparent);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .post-body .code-frame[data-clipped]::after {
    opacity: 1;
  }
  @media print {
    .post-body .code-frame::after {
      display: none;
    }
  }
  .post-body pre,
  .post-body .astro-code {
    margin: 2rem 0;
    padding: 1.4rem 1.6rem;
    overflow-x: auto;
    background: var(--code-bg);
    border: 1px solid var(--glass-hair);
    border-radius: 10px;
    line-height: 1.6;
    /* visible affordance that long lines continue past the clip edge */
    scrollbar-width: thin;
    scrollbar-color: var(--brass-dim) transparent;
  }
  .post-body pre::-webkit-scrollbar {
    height: 8px;
  }
  .post-body pre::-webkit-scrollbar-thumb {
    background: var(--brass-dim);
    border-radius: 4px;
  }
  .post-body .copy-code {
    position: absolute;
    /* above the code-frame ::after fade, which follows it in paint order */
    z-index: 1;
    top: 0.6rem;
    right: 0.6rem;
    cursor: pointer;
    background: var(--glass);
    color: var(--ink-dim);
    border: 1px solid var(--hair);
    border-radius: 6px;
    padding: 0.25rem 0.6rem;
    transition:
      color 0.25s ease,
      border-color 0.25s ease;
  }
  .post-body .copy-code:hover {
    color: var(--brass);
    border-color: var(--brass-dim);
  }
  .post-body pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.82rem;
  }
  /* Shiki dual themes (defaultColor: false): each token carries only
     --shiki-dark/--shiki-light custom props; pick one per theme. */
  .post-body .astro-code,
  .post-body .astro-code span {
    color: var(--shiki-dark);
  }
  [data-theme="light"] .post-body .astro-code,
  [data-theme="light"] .post-body .astro-code span {
    color: var(--shiki-light);
  }

  .end-mark {
    text-align: center;
    margin-top: 3.4rem;
    padding-top: 2.4rem;
    border-top: 1px solid var(--hair);
    color: var(--brass);
    letter-spacing: 0.3em;
  }

  /* prev / next */
  .post-nav {
    max-width: var(--max);
    margin: 0 auto 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
  }
  .post-nav .panel {
    margin: 0;
    padding: 1.6rem 1.8rem;
    text-decoration: none;
    display: block;
  }
  .post-nav .dir {
    display: block;
    margin-bottom: 0.55rem;
  }
  .post-nav h3 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    transition: color 0.3s;
  }
  .post-nav .panel:hover h3 {
    color: var(--brass);
  }
  .post-nav .next {
    text-align: right;
  }
  .post-nav .next:first-child {
    grid-column: 2;
  }

  @media (max-width: 860px) {
    main {
      padding-top: calc(var(--nav-h) + 2.125rem); /* = 6.5rem */
    }
    .post {
      padding: 2.6rem 0 2.2rem;
    }
    /* long identifier pills in headings fit a phone line whole instead of
       fragmenting mid-word */
    .post-body h2 code,
    .post-body h3 code {
      font-size: 0.72em;
    }
    .post-inner {
      padding: 0 1.3rem;
    }
    .post-nav {
      grid-template-columns: 1fr;
      margin-bottom: 3rem;
    }
    .post-nav .next {
      text-align: left;
    }
    .post-nav .next:first-child {
      grid-column: auto;
    }
  }
</style>
