---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const tags = allPosts.flatMap((post) => post.data.tags || []);
  const uniqueTags = [...new Set(tags)];

  return uniqueTags.map((tag) => {
    return {
      params: {
        tag: tag,
      },
      props: {
        posts: allPosts.filter((post) => post.data.tags?.includes(tag)),
      },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;

posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const formatDate = (date: string) =>
  new Date(date + "T12:00:00").toLocaleDateString("en-US", {
    month: "long",
    year: "numeric",
  });
---

<BaseLayout pageTitle={`Transmissions · ${tag} — Zach Callahan`}>
  <div class="panel-wrap">
    <section id="transmissions" class="panel tx-panel">
      <a class="crumb mono" href="/posts">← All Transmissions</a>

      <div class="sec-head">
        <h2><a href="#transmissions">Transmissions</a></h2>
        <span class="mono coord">Tagged · {tag}</span>
      </div>

      {
        posts.map((post) => (
          <a class="tx-row glint-row" href={`/posts/${post.id}`}>
            <h3>{post.data.title}</h3>
            <span class="tx-meta">
              <time class="mono" datetime={post.data.date}>
                {formatDate(post.data.date)}
              </time>
              <span class="arrow">→</span>
            </span>
          </a>
        ))
      }
    </section>
  </div>
</BaseLayout>

<style is:global>
  main {
    padding-top: 8.5rem;
  }

  .tx-panel {
    --head-gap: 2.2rem;
    padding: var(--head-gap) 3rem 2.2rem;
  }

  .crumb {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.3s;
  }
  .crumb:hover {
    color: var(--brass);
  }

  .tx-row {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    justify-content: space-between;
    padding: 1.7rem var(--row-pad);
    text-decoration: none;
  }
  .tx-row h3 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    transition: color 0.3s;
  }
  .tx-row:hover h3 {
    color: var(--brass);
  }
  .tx-row .tx-meta {
    display: flex;
    align-items: baseline;
    gap: 1.4rem;
    white-space: nowrap;
  }
  .tx-row .arrow {
    color: var(--brass);
    font-family: "Spline Sans Mono", monospace;
  }

  @media (max-width: 860px) {
    main {
      padding-top: 6.5rem;
    }
    .tx-panel {
      --head-gap: 1.4rem;
      padding: 1.4rem;
    }
  }
</style>
