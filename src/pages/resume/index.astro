---
import BaseLayout from "@layouts/BaseLayout.astro";
import { toRoman } from "@lib/utils/roman";
import { getCollection, render } from "astro:content";

const MONTHS = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];

interface Month {
  month: number;
  year: number;
}

const monthKey = (m?: Month) =>
  m ? m.year * 12 + m.month : Number.POSITIVE_INFINITY;

const shortDate = (m: Month) => `${MONTHS[m.month - 1]} ${m.year}`;

const jobs = await getCollection("jobs");

const renderedJobs = await Promise.all(
  jobs
    .sort(
      (a, b) =>
        monthKey(b.data.tenure.end) - monthKey(a.data.tenure.end) ||
        monthKey(b.data.tenure.start) - monthKey(a.data.tenure.start),
    )
    .map(async (job) => {
      const { start, end } = job.data.tenure;
      return {
        ...job,
        span: `${toRoman(start.year)} — ${end ? toRoman(end.year) : "Present"}`,
        precise: `${shortDate(start)} — ${end ? shortDate(end) : "Now"}`,
        Content: (await render(job)).Content,
      };
    }),
);

type SkillLevel = "expert" | "advanced";

interface Skill {
  name: string;
  level: SkillLevel;
}

const skills: Skill[] = [
  { name: "Go", level: "expert" },
  { name: "Kubernetes", level: "expert" },
  { name: "Linux", level: "expert" },
  { name: "Bash", level: "expert" },
  { name: "Docker", level: "expert" },
  { name: "AWS", level: "expert" },
  { name: "Terraform", level: "expert" },
  { name: "HTML / CSS", level: "expert" },
  { name: "TypeScript", level: "advanced" },
  { name: "Svelte / SvelteKit", level: "advanced" },
  { name: "Java", level: "advanced" },
  { name: "Pulumi", level: "advanced" },
  { name: "OpenTelemetry", level: "advanced" },
  { name: "Technical Writing", level: "advanced" },
  { name: "Git", level: "advanced" },
];

const eyebrow = `Personnel Dossier · ${toRoman(new Date().getFullYear())}`;

const footerLinks = [
  { label: "GitHub", href: "https://github.com/theZMC" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/thezmc/" },
  { label: "Writing", href: "/posts" },
  { label: "Home", href: "/" },
];
---

<BaseLayout
  pageTitle="Zach Callahan — Resume · zmc.dev"
  metaDescription="Zach Callahan's professional resume"
  {footerLinks}
 
>
  <div class="resume panel-wrap">
    <section class="panel">
      <div class="dossier-head">
        <div>
          <span class="mono eyebrow">{eyebrow}</span>
          <h1>ZACH CALLAHAN</h1>
          <p class="designation">SysAdmin turned Software Engineer</p>
          <span class="mono loc">Arkansas, United States · zmc.dev</span>
        </div>
        <div class="actions">
          <a class="action primary" href="/ZachCallahanResume.pdf">
            Download PDF <span class="glyph">⇩</span>
          </a>
          <button class="action" onclick="window.print()">
            Print Dossier <span class="glyph">⎙</span>
          </button>
          <a class="action" href="mailto:zach@zmc.dev">
            zach@zmc.dev <span class="glyph">→</span>
          </a>
          <a class="action" href="tel:14794595787">
            1 (479) 459-5787 <span class="glyph">→</span>
          </a>
        </div>
      </div>
    </section>

    <section id="profile" class="panel">
      <div class="sec-head">
        <h2><a href="#profile">Profile</a></h2>
        <span class="mono coord">Section I</span>
      </div>
      <div class="profile-grid">
        <p class="lede">
          Software engineer by way of system administration — and before that,
          retail floors and field medicine. Automation and tooling are the
          passion; the goal is to <em
            >make my team's job easier today than it was yesterday.</em
          > Mostly self-taught, working with Linux daily since 2006, and a firm
          believer that the best solutions are built by communities.
        </p>
        <div class="body-col">
          <p>
            Bash and Go are the languages I reach for most, but I'm always
            adding to the toolbox. Whether on a team or solo, I strive to leave
            things better than I found them.
          </p>
          <p>
            Nine years in retail management taught me how to identify people's
            strengths and develop them — everyone has at least one. Six years
            as a combat medic in the Arkansas Army National Guard (honorably
            discharged 2017) taught me leadership and teamwork under pressure.
          </p>
          <p>
            I also teach frontend fundamentals at the Arkansas Coding Academy.
            Off the clock: tinkering with computers and electronics, my
            girlfriend, and our three dogs.
          </p>
        </div>
      </div>
    </section>

    <section id="calibration" class="panel">
      <div class="sec-head">
        <h2><a href="#calibration">Instrument Calibration</a></h2>
        <span class="mono coord">Section II</span>
      </div>
      <div class="cal-legend mono">
        <span><i class="dot expert"></i> Expert</span>
        <span><i class="dot advanced"></i> Advanced</span>
      </div>
      <div class="skills">
        {
          skills.map((skill) => (
            <span class="skill">
              <i class={`dot ${skill.level}`} /> {skill.name}
            </span>
          ))
        }
      </div>
    </section>

    <section id="record" class="panel">
      <div class="sec-head">
        <h2><a href="#record">Service Record</a></h2>
        <span class="mono coord">Section III · Complete</span>
      </div>

      {
        renderedJobs.map((job) => (
          <div class="svc-row">
            <div class="svc-when">
              <span class="span">{job.span}</span>
              <span class="mono precise">{job.precise}</span>
            </div>
            <div>
              <h3>{job.data.company}</h3>
              <span class="mono post">{job.data.title}</span>
              <job.Content />
              <div class="tags">
                {job.data.skills.map((skill) => (
                  <span class="tag">{skill}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </section>
  </div>
</BaseLayout>

<style>
  .resume {
    padding-top: 8.5rem;
  }

  .panel {
    margin: 0 auto 3rem;
    padding: 3rem 3rem 2.4rem;
  }

  .sec-head h2 {
    font-size: 1.4rem;
  }

  /* ---------- dossier header ---------- */
  .dossier-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2.5rem;
    align-items: start;
  }
  .dossier-head .eyebrow {
    color: var(--brass);
    letter-spacing: 0.3em;
    display: block;
    margin-bottom: 1.2rem;
  }
  .dossier-head h1 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: clamp(2rem, 4.6vw, 3.2rem);
    letter-spacing: 0.12em;
    line-height: 1.15;
  }
  .dossier-head .designation {
    margin-top: 0.8rem;
    font-family: "Marcellus", serif;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    color: var(--brass);
  }
  .dossier-head .loc {
    margin-top: 1.2rem;
    display: block;
  }
  .actions {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    align-items: stretch;
    min-width: 220px;
  }
  .action {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    cursor: pointer;
    font-family: "Spline Sans Mono", monospace;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    background: none;
    border: 1px solid var(--hair);
    border-radius: 8px;
    padding: 0.75rem 1.1rem;
    transition:
      border-color 0.3s,
      color 0.3s,
      background 0.3s;
  }
  .action:hover {
    border-color: var(--brass);
    color: var(--brass);
  }
  .action .glyph {
    color: var(--brass);
  }
  .action.primary {
    border-color: var(--brass-dim);
    color: var(--brass);
  }
  .action.primary:hover {
    background: var(--brass);
    color: var(--bg);
    border-color: var(--brass);
  }
  .action.primary:hover .glyph {
    color: var(--bg);
  }

  /* ---------- profile ---------- */
  .profile-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 3.5rem;
    padding-top: 2.4rem;
  }
  .profile-grid .lede {
    font-size: 1.2rem;
    line-height: 1.75;
  }
  .profile-grid .lede em {
    font-style: normal;
    color: var(--brass);
  }
  .profile-grid .body-col p {
    color: var(--ink-dim);
    font-size: 0.95rem;
    margin-bottom: 1.2rem;
  }

  /* ---------- skills / calibration ---------- */
  .cal-legend {
    display: flex;
    gap: 2rem;
    padding: 1.6rem 0 0.4rem;
  }
  .cal-legend span {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
    flex: none;
  }
  .dot.expert {
    background: var(--brass);
  }
  .dot.advanced {
    background: none;
    border: 1px solid var(--celest);
  }
  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 0.4rem 2rem;
    padding-top: 1rem;
  }
  .skill {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-bottom: 1px dashed var(--hair);
    font-family: "Spline Sans Mono", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  /* ---------- service record (full) ---------- */
  .svc-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2.4rem;
    padding: 2.4rem 0;
    border-bottom: 1px solid var(--hair);
  }
  .svc-row:last-of-type {
    border-bottom: none;
    padding-bottom: 0.6rem;
  }
  .svc-when .span {
    display: block;
    font-family: "Marcellus", serif;
    color: var(--brass);
    font-size: 1rem;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }
  .svc-when .precise {
    display: block;
    margin-top: 0.5rem;
  }
  .svc-row h3 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.35rem;
    letter-spacing: 0.05em;
  }
  .svc-row .post {
    display: block;
    margin: 0.35rem 0 0.8rem;
    color: var(--brass);
  }
  .svc-row :global(p) {
    color: var(--ink-dim);
    font-size: 0.95rem;
    max-width: 52em;
    margin-bottom: 1.1rem;
  }
  .svc-row .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .tag {
    padding: 0.26rem 0.68rem;
  }

  @media (max-width: 860px) {
    .resume {
      padding-top: 6.5rem;
    }
    .panel {
      padding: 2.2rem 1.4rem 1.6rem;
      margin-bottom: 2rem;
    }
    .dossier-head {
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }
    .actions {
      min-width: 0;
    }
    .profile-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .svc-row {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      padding: 2rem 0;
    }
    .svc-when .precise {
      margin-top: 0.2rem;
    }
  }

  /* ============ PRINT: dossier declassified ============
     Scoped like the rules above so each override ties its base rule's
     specificity and wins by source order. Cross-component chrome
     (body, main, nav, footer, .cosmos) is handled in the global block. */
  @media print {
    .resume {
      padding-top: 0;
    }
    .actions {
      display: none;
    }
    .panel {
      background: none;
      border: none;
      border-radius: 0;
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      max-width: 100%;
      margin: 0 0 1.2rem;
      padding: 0 0 0.8rem;
      break-inside: avoid;
    }
    .panel::before {
      display: none;
    }
    .mono {
      color: #555;
    }
    .dossier-head h1 {
      font-size: 22pt;
      letter-spacing: 0.06em;
    }
    .dossier-head .designation,
    .svc-when .span,
    .svc-row .post,
    .dossier-head .eyebrow,
    .profile-grid .lede em {
      color: #111;
    }
    .sec-head {
      border-bottom: 1pt solid #111;
    }
    .svc-row {
      border-bottom: 0.5pt solid #bbb;
      padding: 0.8rem 0;
      grid-template-columns: 160px 1fr;
      gap: 1rem;
    }
    .svc-row :global(p),
    .profile-grid .body-col p {
      color: #333;
    }
    .tag {
      color: #555;
      border-color: #bbb;
    }
    .dot.expert {
      background: #111;
    }
    .dot.advanced {
      border-color: #555;
    }
    .skill {
      border-bottom: none;
      padding: 0.15rem 0;
    }
    a {
      text-decoration: none;
    }
  }
</style>

<style is:global>
  /* Print: hide the shared chrome and flatten the page ground. The
     display overrides carry !important (verbatim from the approved
     mockup) because Nav/Footer set their own scoped display values. */
  @media print {
    .cosmos,
    nav,
    footer {
      display: none !important;
    }
    body {
      background: #fff;
      color: #111;
      font-size: 11pt;
      line-height: 1.5;
    }
    main {
      padding-top: 0;
    }
  }
</style>
