---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const formatDate = (date: string) =>
  new Date(date + "T12:00:00").toLocaleDateString("en-US", {
    month: "long",
    year: "numeric",
  });
---

<BaseLayout pageTitle="Transmissions — Zach Callahan" trimNavOnMobile>
  <div class="panel-wrap">
    <section class="panel tx-panel">
      <div class="sec-head">
        <h2>Transmissions</h2>
        <span class="mono coord">Field Notes · Plaintext</span>
      </div>

      {
        posts.map((post) => (
          <a class="tx-row glint-row" href={`/posts/${post.id}`}>
            <h3>{post.data.title}</h3>
            <span class="tx-meta">
              <span class="mono">{formatDate(post.data.date)}</span>
              <span class="arrow">→</span>
            </span>
          </a>
        ))
      }
    </section>
  </div>
</BaseLayout>

<style is:global>
  main {
    padding-top: 8.5rem;
  }

  .tx-panel {
    padding: 3.2rem 3rem 2.2rem;
  }

  .tx-row {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    justify-content: space-between;
    padding: 1.7rem var(--row-pad);
    text-decoration: none;
  }
  .tx-row h3 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    transition: color 0.3s;
  }
  .tx-row:hover h3 {
    color: var(--brass);
  }
  .tx-row .tx-meta {
    display: flex;
    align-items: baseline;
    gap: 1.4rem;
    white-space: nowrap;
  }
  .tx-row .arrow {
    color: var(--brass);
    font-family: "Spline Sans Mono", monospace;
  }

  @media (max-width: 860px) {
    main {
      padding-top: 6.5rem;
    }
    .tx-panel {
      padding: 2.2rem 1.4rem 1.4rem;
    }
  }
</style>
