---
import EclipseToggle from "@components/EclipseToggle.astro";
import ProgressDial from "@components/ProgressDial.astro";

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  links?: NavLink[];
  showProgress?: boolean;
}

const {
  links = [
    { label: "Writing", href: "/posts" },
    { label: "Resume", href: "/resume" },
  ],
  showProgress = false,
} = Astro.props;
---

<nav>
  <a class="sigil" href="/">Z·M·C</a>
  <div class="nav-right">
    <ul>
      {
        links.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>
    {showProgress && <ProgressDial />}
    <EclipseToggle />
  </div>
</nav>
