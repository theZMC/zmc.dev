<!-- Fixed cosmos: sun sits just below the nav; orbits turn with scroll -->
<div class="cosmos" aria-hidden="true">
  <svg class="orrery" viewBox="0 0 1000 1000">
    <defs>
      <!-- label paths: circles starting at 12 o'clock, running clockwise -->
      <path id="lp72" d="M 500 428 A 72 72 0 1 1 499.98 428"></path>
      <path id="lp110" d="M 500 390 A 110 110 0 1 1 499.98 390"></path>
      <path id="lp152" d="M 500 348 A 152 152 0 1 1 499.98 348"></path>
      <path id="lp196" d="M 500 304 A 196 196 0 1 1 499.98 304"></path>
      <path id="lp242" d="M 500 258 A 242 242 0 1 1 499.98 258"></path>
      <path id="lp294" d="M 500 206 A 294 294 0 1 1 499.98 206"></path>
      <path id="lpVI" d="M 500 148 A 360 352 0 1 1 499.98 148"></path>
      <path id="lp410" d="M 500 90  A 410 410 0 1 1 499.98 90"></path>
      <path id="lpComet" d="M 695 368.85 A 235 131.15 0 1 1 694.98 368.85"
      ></path>
    </defs>

    <!-- static graticule: radial lines + degree ring (ticks generated by script) -->
    <g id="graticule" stroke="var(--grat)" stroke-width=".6"></g>
    <circle
      cx="500"
      cy="500"
      r="456"
      fill="none"
      stroke="var(--orb-outer)"
      stroke-width=".7"></circle>
    <circle
      cx="500"
      cy="500"
      r="462"
      fill="none"
      stroke="var(--orb-outer)"
      stroke-width=".7"></circle>
    <g id="degreeRing"></g>

    <!-- compass star behind the sun -->
    <g stroke="var(--tick)" stroke-width=".6" fill="none">
      <path
        d="M 500 452 L 505 495 L 548 500 L 505 505 L 500 548 L 495 505 L 452 500 L 495 495 Z"
      ></path>
      <path
        d="M 524 476 L 506 494 M 524 524 L 506 506 M 476 524 L 494 506 M 476 476 L 494 494"
        stroke-width=".45"></path>
    </g>

    <!-- the sun, drawn as its chart symbol: ☉ -->
    <circle
      cx="500"
      cy="500"
      r="11"
      fill="none"
      stroke="var(--brass)"
      stroke-width=".8"></circle>
    <circle cx="500" cy="500" r="2.6" fill="var(--brass)"></circle>

    <!-- I -->
    <g class="orbit-group" data-rate="0.10">
      <path
        class="gap-ring"
        data-label-pad="5"
        d="M 500 428 A 72 72 0 1 1 499.98 428"
        fill="none"
        stroke="var(--orb-brass)"
        stroke-width=".6"></path>
      <circle cx="572" cy="500" r="1.8" fill="var(--brass)"></circle>
      <text class="orbit-label"
        ><textPath href="#lp72" startOffset="2%">ORBIS·I</textPath></text
      >
    </g>

    <!-- II -->
    <g class="orbit-group" data-rate="-0.078">
      <path
        class="gap-ring"
        data-label-pad="5"
        d="M 500 390 A 110 110 0 1 1 499.98 390"
        fill="none"
        stroke="var(--orb-ink)"
        stroke-width=".6"></path>
      <circle cx="500" cy="390" r="2.2" fill="var(--ink)" opacity=".75"
      ></circle>
      <text class="orbit-label"
        ><textPath href="#lp110" startOffset="35%">ORBIS·II</textPath></text
      >
    </g>

    <!-- III: brass planet + retrograde moon -->
    <g class="orbit-group" data-rate="0.058">
      <path
        class="gap-ring"
        data-label-pad="5"
        d="M 500 348 A 152 152 0 1 1 499.98 348"
        fill="none"
        stroke="var(--orb-brass)"
        stroke-width=".7"></path>
      <circle cx="652" cy="500" r="3" fill="var(--brass)"></circle>
      <circle
        cx="652"
        cy="500"
        r="9"
        fill="none"
        stroke="var(--orb-brass)"
        stroke-width=".4"></circle>
      <g class="moon-orbit" data-rate="-0.45" data-cx="652" data-cy="500">
        <circle cx="661" cy="500" r="1.1" fill="var(--ink)" opacity=".8"
        ></circle>
      </g>
      <text class="orbit-label brass"
        ><textPath href="#lp152" startOffset="55%"
          >ORBIS·III · LVNA·RETROGRADA</textPath
        ></text
      >
    </g>

    <!-- IV -->
    <g class="orbit-group" data-rate="-0.044">
      <path
        class="gap-ring"
        data-label-pad="5"
        d="M 500 304 A 196 196 0 1 1 499.98 304"
        fill="none"
        stroke="var(--orb-celest)"
        stroke-width=".6"></path>
      <circle cx="361" cy="361" r="2.4" fill="var(--celest)"></circle>
      <text class="orbit-label"
        ><textPath href="#lp196" startOffset="18%">ORBIS·IV</textPath></text
      >
    </g>

    <!-- V: ringed giant -->
    <g class="orbit-group" data-rate="0.033">
      <path
        class="gap-ring"
        data-label-pad="5"
        d="M 500 258 A 242 242 0 1 1 499.98 258"
        fill="none"
        stroke="var(--orb-ink)"
        stroke-width=".6"></path>
      <circle cx="742" cy="500" r="4" fill="var(--ink)" opacity=".8"></circle>
      <ellipse
        cx="742"
        cy="500"
        rx="9.5"
        ry="3.2"
        fill="none"
        stroke="var(--orb-brass)"
        stroke-width=".6"
        transform="rotate(-18 742 500)"></ellipse>
      <text class="orbit-label"
        ><textPath href="#lp242" startOffset="68%">ORBIS·V · ANNVLATVS</textPath
        ></text
      >
    </g>

    <!-- asteroid belt -->
    <g class="orbit-group" data-rate="-0.020">
      <circle
        cx="500"
        cy="500"
        r="286"
        fill="none"
        stroke="var(--orb-ink)"
        stroke-width=".45"
        stroke-dasharray="1 6"></circle>
      <circle
        cx="500"
        cy="500"
        r="302"
        fill="none"
        stroke="var(--orb-ink)"
        stroke-width=".45"
        stroke-dasharray="1 6"></circle>
      <circle cx="793" cy="512" r="1.1" fill="var(--ink)" opacity=".55"
      ></circle>
      <circle cx="760" cy="644" r="1.3" fill="var(--brass)" opacity=".5"
      ></circle>
      <circle cx="705" cy="713" r="1" fill="var(--ink)" opacity=".5"></circle>
      <circle cx="643" cy="759" r="1.2" fill="var(--celest)" opacity=".6"
      ></circle>
      <circle cx="494" cy="798" r="1" fill="var(--ink)" opacity=".55"></circle>
      <circle cx="348" cy="752" r="1.3" fill="var(--brass)" opacity=".45"
      ></circle>
      <circle cx="288" cy="705" r="1" fill="var(--ink)" opacity=".5"></circle>
      <circle cx="240" cy="644" r="1.2" fill="var(--celest)" opacity=".55"
      ></circle>
      <circle cx="209" cy="496" r="1.1" fill="var(--ink)" opacity=".55"
      ></circle>
      <circle cx="247" cy="355" r="1" fill="var(--brass)" opacity=".5"></circle>
      <circle cx="294" cy="288" r="1.2" fill="var(--ink)" opacity=".5"></circle>
      <circle cx="355" cy="241" r="1" fill="var(--celest)" opacity=".55"
      ></circle>
      <circle cx="503" cy="207" r="1.2" fill="var(--ink)" opacity=".55"
      ></circle>
      <circle cx="650" cy="247" r="1" fill="var(--brass)" opacity=".5"></circle>
      <circle cx="711" cy="293" r="1.2" fill="var(--ink)" opacity=".5"></circle>
      <circle cx="757" cy="352" r="1" fill="var(--celest)" opacity=".55"
      ></circle>
      <text class="orbit-label"
        ><textPath href="#lp294" startOffset="40%">CINGVLVM·ASTEROIDVM</textPath
        ></text
      >
    </g>

    <!-- VI -->
    <g class="orbit-group" data-rate="0.016">
      <path
        class="gap-ring"
        data-label-pad="5"
        d="M 500 148 A 360 352 0 1 1 499.98 148"
        fill="none"
        stroke="var(--orb-celest)"
        stroke-width=".6"></path>
      <circle cx="146" cy="450" r="2.6" fill="var(--celest)"></circle>
      <text class="orbit-label"
        ><textPath href="#lpVI" startOffset="8%">ORBIS·VI</textPath></text
      >
    </g>

    <!-- VII: planet + trojans -->
    <g class="orbit-group" data-rate="-0.011">
      <path
        class="gap-ring"
        data-label-pad="5"
        d="M 500 90  A 410 410 0 1 1 499.98 90"
        fill="none"
        stroke="var(--orb-ink)"
        stroke-width=".6"></path>
      <circle cx="115" cy="360" r="2.8" fill="var(--ink)" opacity=".8"></circle>
      <circle cx="205" cy="215" r="1.2" fill="var(--ink)" opacity=".5"></circle>
      <circle cx="145" cy="705" r="1.2" fill="var(--ink)" opacity=".5"></circle>
      <text class="orbit-label"
        ><textPath href="#lp410" startOffset="62%"
          >ORBIS·VII · CVM·TROIANIS</textPath
        ></text
      >
    </g>

    <!-- comet: track fixed in space, sun at the focus; the body travels the path.
         a=235, b=131.15, c=195 (e≈0.830) → perihelion 40, aphelion 430.
         The static rotate is the argument of perihelion, not motion. -->
    <g transform="rotate(25 500 500)">
      <path
        class="gap-ring"
        data-label-pad="5"
        d="M 695 368.85 A 235 131.15 0 1 1 694.98 368.85"
        fill="none"
        stroke="var(--orb-celest)"
        stroke-width=".55"></path>
      <circle id="cometBody" cx="460" cy="500" r="1.8" fill="var(--celest)"
      ></circle>
      <line
        id="cometTail"
        x1="460"
        y1="500"
        x2="444"
        y2="500"
        stroke="var(--orb-celest)"
        stroke-width=".8"></line>
      <text class="orbit-label"
        ><textPath href="#lpComet" startOffset="12%"
          >COMETA · VIA·EXCENTRICA</textPath
        ></text
      >
    </g>
  </svg>
</div>
