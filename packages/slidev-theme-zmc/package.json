{
  "name": "slidev-theme-zmc",
  "version": "0.1.0",
  "private": true,
  "description": "A Slidev theme in the zmc.dev design language — brass instruments and celestial charts on midnight glass.",
  "keywords": [
    "slidev-theme",
    "slidev",
    "theme",
    "zmc"
  ],
  "author": "Zach Callahan",
  "engines": {
    "node": ">=18.0.0",
    "slidev": ">=52.0.0"
  },
  "slidev": {
    "colorSchema": "both",
    "highlighter": "shiki",
    "defaults": {
      "transition": "fade",
      "fonts": {
        "provider": "none",
        "sans": "Instrument Sans",
        "serif": "Marcellus",
        "mono": "Spline Sans Mono"
      }
    }
  },
  "scripts": {
    "dev": "slidev example.md",
    "build": "slidev build example.md",
    "export": "slidev export example.md"
  },
  "dependencies": {
    "@fontsource/cormorant": "^5.2.8",
    "@fontsource/instrument-sans": "^5.2.8",
    "@fontsource/marcellus": "^5.2.8",
    "@fontsource/spline-sans-mono": "^5.2.8"
  },
  "devDependencies": {
    "@slidev/cli": "^52.17.0",
    "@slidev/types": "^52.17.0",
    "playwright-chromium": "^1.61.1",
    "vue": "^3.5.13"
  }
}
