---
import BaseLayout from "@layouts/BaseLayout.astro";
import { loadResume } from "@lib/resume/load";
import { toRoman } from "@lib/utils/roman";
import { byTenureDesc, romanSpan, shortDate } from "@lib/utils/tenure";

const resume = await loadResume();

const jobs = [...resume.jobs].sort(byTenureDesc).map((job) => {
  const { start, end } = job.tenure;
  return {
    ...job,
    span: romanSpan(job.tenure),
    precise: `${shortDate(start)} — ${end ? shortDate(end) : "Now"}`,
  };
});

const pdfFilename = `${resume.name} - Resume.pdf`;

const eyebrow = `Personnel Dossier · ${toRoman(new Date().getFullYear())}`;

const footerLinks = [
  { label: "GitHub", href: resume.github },
  { label: "LinkedIn", href: resume.linkedin },
  { label: "Writing", href: "/posts" },
  { label: "Home", href: "/" },
];
---

<BaseLayout
  pageTitle="Zach Callahan — Resume · zmc.dev"
  metaDescription="Zach Callahan's professional resume"
  {footerLinks}
>
  <div class="resume panel-wrap">
    <section class="panel">
      <div class="dossier-head">
        <div>
          <span class="mono eyebrow">{eyebrow}</span>
          <h1>{resume.name.toUpperCase()}</h1>
          <p class="designation">{resume.designation}</p>
          <span class="mono loc">{resume.location} · {resume.site}</span>
        </div>
        <div class="actions">
          <button
            id="download-pdf"
            class="action primary"
            data-filename={pdfFilename}
          >
            <span class="label">Download PDF</span>
            <span class="glyph">⇩</span>
          </button>
          <button id="print-pdf" class="action">
            <span class="label">Print Resume</span>
            <span class="glyph">⎙</span>
          </button>
          <a class="action" href={`mailto:${resume.email}`}>
            {resume.email}
            <span class="glyph">→</span>
          </a>
          <a class="action" href={`tel:${resume.phone.tel}`}>
            {resume.phone.display}
            <span class="glyph">→</span>
          </a>
        </div>
      </div>
    </section>

    <section id="profile" class="panel">
      <div class="sec-head">
        <h2><a href="#profile">Profile</a></h2>
        <span class="mono coord">Section I</span>
      </div>
      <div class="profile-grid">
        <p class="lede" set:html={resume.profile.lede} />
        <div class="body-col">
          {resume.profile.body.map((para) => <p set:html={para} />)}
        </div>
      </div>
    </section>

    <section id="calibration" class="panel">
      <div class="sec-head">
        <h2><a href="#calibration">Instrument Calibration</a></h2>
        <span class="mono coord">Section II</span>
      </div>
      <div class="cal-legend mono">
        <span class="key">Key</span>
        <span><i class="dot expert"></i> Expert</span>
        <span><i class="dot advanced"></i> Advanced</span>
      </div>
      <div class="skills">
        {
          resume.skills.map((skill) => (
            <span class="skill">
              <i class={`dot ${skill.level}`} /> {skill.name}
            </span>
          ))
        }
      </div>
    </section>

    <section id="record" class="panel">
      <div class="sec-head">
        <h2><a href="#record">Service Record</a></h2>
        <span class="mono coord">Section III · Complete</span>
      </div>

      {
        jobs.map((job) => (
          <div class="svc-row">
            <div class="svc-when">
              <span class="span">{job.span}</span>
              <span class="mono precise">{job.precise}</span>
            </div>
            <div>
              <h3>{job.company}</h3>
              <span class="mono post">{job.title}</span>
              <p>{job.body}</p>
              <div class="tags">
                {job.skills.map((skill) => (
                  <span class="tag">{skill}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </section>

    <section id="credentials" class="panel">
      <div class="sec-head">
        <h2><a href="#credentials">Credentials</a></h2>
        <span class="mono coord">Section IV</span>
      </div>
      {
        resume.certifications.map((cert) => (
          <div class="cred-row">
            <div class="cred-when">
              <span class="mono">{cert.short}</span>
            </div>
            <div>
              <h3>{cert.name}</h3>
              <span class="mono cred-meta">
                {cert.issuer}
                {cert.year ? ` · ${cert.year}` : ""}
              </span>
            </div>
          </div>
        ))
      }
    </section>
  </div>

  {/* Full resume payload for the in-browser PDF generator. */}
  <script
    type="application/json"
    id="resume-pdf-data"
    set:html={JSON.stringify(resume).replace(/</g, "\\u003c")}
  />
</BaseLayout>

<script>
  import type { Resume } from "@lib/resume/schema";

  const downloadBtn = document.getElementById(
    "download-pdf",
  ) as HTMLButtonElement | null;
  const printBtn = document.getElementById(
    "print-pdf",
  ) as HTMLButtonElement | null;

  // One render per visit: both buttons share the generated blob.
  let blobUrl: string | undefined;
  async function resumePdfUrl(): Promise<string> {
    if (blobUrl) return blobUrl;
    const payload = document.getElementById("resume-pdf-data")?.textContent;
    if (!payload) throw new Error("resume PDF data missing");
    const data = JSON.parse(payload) as Resume;
    const { generateResumePdf } = await import("@lib/resume-pdf/generate");
    blobUrl = URL.createObjectURL(await generateResumePdf(data));
    return blobUrl;
  }

  function setBusy(btn: HTMLButtonElement, on: boolean, failed = false) {
    const label = btn.querySelector(".label");
    if (!label) return;
    if (!btn.dataset.idleLabel) btn.dataset.idleLabel = label.textContent ?? "";
    btn.disabled = on;
    btn.setAttribute("aria-busy", String(on));
    label.textContent = on
      ? "Preparing…"
      : failed
        ? "Failed — try again"
        : btn.dataset.idleLabel;
  }

  downloadBtn?.addEventListener("click", async () => {
    setBusy(downloadBtn, true);
    try {
      const url = await resumePdfUrl();
      const anchor = document.createElement("a");
      anchor.href = url;
      anchor.download = downloadBtn.dataset.filename ?? "Resume.pdf";
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      setBusy(downloadBtn, false);
    } catch (error) {
      console.error(error);
      setBusy(downloadBtn, false, true);
    }
  });

  printBtn?.addEventListener("click", async () => {
    // Open synchronously so Safari's popup blocker allows the tab; point it
    // at the blob once the render finishes.
    const tab = window.open("about:blank", "_blank");
    setBusy(printBtn, true);
    try {
      const url = await resumePdfUrl();
      if (tab) tab.location.href = url;
      else window.location.href = url;
      setBusy(printBtn, false);
    } catch (error) {
      console.error(error);
      tab?.close();
      setBusy(printBtn, false, true);
    }
  });
</script>

<style>
  .resume {
    padding-top: calc(var(--nav-h) + 4.125rem); /* = 8.5rem */
  }

  .panel {
    margin: 0 auto 3rem;
    padding: 3rem 3rem 2.4rem;
  }

  .sec-head h2 {
    font-size: 1.4rem;
  }

  /* ---------- dossier header ---------- */
  .dossier-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2.5rem;
    align-items: start;
  }
  .dossier-head .eyebrow {
    color: var(--brass);
    letter-spacing: 0.3em;
    display: block;
    margin-bottom: 1.2rem;
  }
  .dossier-head h1 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: clamp(2rem, 4.6vw, 3.2rem);
    letter-spacing: 0.12em;
    line-height: 1.15;
  }
  .dossier-head .designation {
    margin-top: 0.8rem;
    font-family: "Marcellus", serif;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    color: var(--brass);
  }
  .dossier-head .loc {
    margin-top: 1.2rem;
    display: block;
  }
  .actions {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    align-items: stretch;
    min-width: 220px;
  }
  .action {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    cursor: pointer;
    font-family: "Spline Sans Mono", monospace;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    background: none;
    border: 1px solid var(--hair);
    border-radius: 8px;
    padding: 0.75rem 1.1rem;
    transition:
      border-color 0.3s,
      color 0.3s,
      background 0.3s;
  }
  .action:hover {
    border-color: var(--brass);
    color: var(--brass);
  }
  .action .glyph {
    color: var(--brass);
  }
  .action.primary {
    border-color: var(--brass-dim);
    color: var(--brass);
  }
  .action.primary:hover {
    background: var(--brass);
    color: var(--bg);
    border-color: var(--brass);
  }
  .action.primary:hover .glyph {
    color: var(--bg);
  }
  button.action[disabled] {
    opacity: 0.6;
    cursor: progress;
  }

  /* ---------- profile ---------- */
  .profile-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 3.5rem;
    padding-top: 2.4rem;
  }
  .profile-grid .lede {
    font-size: 1.2rem;
    line-height: 1.75;
  }
  /* :global — the lede is injected via set:html, so its em is unscoped */
  .profile-grid .lede :global(em) {
    font-style: normal;
    font-weight: 600;
  }
  .profile-grid .body-col p {
    color: var(--ink-dim);
    font-size: 0.95rem;
    margin-bottom: 1.2rem;
  }

  /* ---------- skills / calibration ---------- */
  /* Chart-key furniture, not content: label-toned and smaller than the
     skill rows, tagged KEY in brass, closed off by a dashed rule. */
  .cal-legend {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.6rem 0 0.4rem;
    font-size: 0.62rem;
    color: var(--ink-dim);
  }
  .cal-legend .key {
    color: var(--brass);
    letter-spacing: 0.3em;
  }
  .cal-legend span {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .cal-legend::after {
    content: "";
    flex: 1;
    border-top: 1px dashed var(--hair);
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
    flex: none;
  }
  .dot.expert {
    background: var(--brass);
  }
  .dot.advanced {
    background: none;
    border: 1px solid var(--celest);
  }
  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 0.4rem 2rem;
    padding-top: 1rem;
  }
  .skill {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-bottom: 1px dashed var(--hair);
    font-family: "Spline Sans Mono", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  /* ---------- service record (full) ---------- */
  .svc-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2.4rem;
    padding: 2.4rem 0;
    background: var(--brass-rule) center bottom / 100% 1px no-repeat;
  }
  .svc-row:last-of-type {
    background: none;
    padding-bottom: 0.6rem;
  }
  .svc-when .span {
    display: block;
    font-family: "Marcellus", serif;
    color: var(--brass);
    font-size: 1rem;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }
  .svc-when .precise {
    display: block;
    margin-top: 0.5rem;
  }
  .svc-row h3 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.35rem;
    letter-spacing: 0.05em;
  }
  .svc-row .post {
    display: block;
    margin: 0.35rem 0 0.8rem;
    color: var(--brass);
  }
  .svc-row :global(p) {
    color: var(--ink-dim);
    font-size: 0.95rem;
    max-width: 52em;
    margin-bottom: 1.1rem;
  }
  .svc-row .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .tag {
    padding: 0.26rem 0.68rem;
  }

  /* ---------- credentials ---------- */
  .cred-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2.4rem;
    padding: 1.6rem 0;
    background: var(--brass-rule) center bottom / 100% 1px no-repeat;
  }
  .cred-row:last-of-type {
    background: none;
    padding-bottom: 0.6rem;
  }
  .cred-when .mono {
    color: var(--brass);
  }
  .cred-row h3 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
  }
  .cred-meta {
    display: block;
    margin-top: 0.35rem;
  }

  @media (max-width: 860px) {
    .resume {
      padding-top: calc(var(--nav-h) + 2.125rem); /* = 6.5rem */
    }
    .panel {
      padding: 2.2rem 1.4rem 1.6rem;
      margin-bottom: 2rem;
    }
    .dossier-head {
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }
    .actions {
      min-width: 0;
    }
    .profile-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .svc-row {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      padding: 2rem 0;
    }
    .cred-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
      padding: 1.4rem 0;
    }
    .svc-when .precise {
      margin-top: 0.2rem;
    }
  }

  /* ============ PRINT: dossier declassified ============
     Scoped like the rules above so each override ties its base rule's
     specificity and wins by source order. Cross-component chrome
     (body, main, nav, footer, .cosmos) is handled in global.css. */
  @media print {
    .resume {
      padding-top: 0;
    }
    .actions {
      min-width: 0;
      gap: 0.35rem;
      align-items: flex-end;
    }
    .action.primary,
    button.action {
      display: none;
    }
    .action {
      border: none;
      padding: 0;
      color: #111;
    }
    .action .glyph {
      display: none;
    }
    .panel {
      background: none;
      border: none;
      border-radius: 0;
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      max-width: 100%;
      margin: 0 0 1.2rem;
      padding: 0 0 0.8rem;
      break-inside: avoid;
    }
    .panel::before {
      display: none;
    }
    .mono {
      color: #555;
    }
    .dossier-head h1 {
      font-size: 22pt;
      letter-spacing: 0.06em;
    }
    .dossier-head .designation,
    .svc-when .span,
    .svc-row .post,
    .dossier-head .eyebrow {
      color: #111;
    }
    .sec-head {
      border-bottom: 1pt solid #111;
    }
    .svc-row {
      background: none;
      border-bottom: 0.5pt solid #bbb;
      padding: 0.8rem 0;
      grid-template-columns: 160px 1fr;
      gap: 1rem;
    }
    .cred-row {
      background: none;
      border-bottom: 0.5pt solid #bbb;
      padding: 0.6rem 0;
      grid-template-columns: 160px 1fr;
      gap: 1rem;
    }
    .cred-when .mono {
      color: #111;
    }
    .svc-row :global(p),
    .profile-grid .body-col p {
      color: #333;
    }
    .tag {
      color: #555;
      border-color: #bbb;
    }
    .dot.expert {
      background: #111;
    }
    .dot.advanced {
      border-color: #555;
    }
    .skill {
      border-bottom: none;
      padding: 0.15rem 0;
    }
    a {
      text-decoration: none;
    }
  }
</style>
