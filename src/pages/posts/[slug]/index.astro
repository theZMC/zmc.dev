---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import {
  byDateAsc,
  formatPostDate,
  parsePostDate,
  toIsoTimestamp,
} from "@lib/utils/dates";
import { toRoman } from "@lib/utils/roman";

export const getStaticPaths = async () => {
  const posts = (await getCollection("blog")).sort(byDateAsc);
  // prev/next walk the published sequence only, so a draft never leaks
  // into a live post's footer nav — drafts still build their own page
  // (with published neighbors), per the schema's contract.
  const nearestPublished = (from: number, step: number) => {
    for (let i = from + step; i >= 0 && i < posts.length; i += step) {
      if (posts[i].data.published) return posts[i];
    }
    return undefined;
  };
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: nearestPublished(i, -1),
      next: nearestPublished(i, 1),
    },
  }));
};

const { post, prev, next } = Astro.props;

const date = parsePostDate(post.data.date);
const eyebrow = `Transmission · ${toRoman(date.getFullYear())} · ${String(
  date.getMonth() + 1,
).padStart(2, "0")}`;
const longDate = formatPostDate(post.data.date);

const words = post.body ? post.body.split(/\s+/).filter(Boolean).length : 0;
const readTime = `${Math.max(1, Math.round(words / 200))} min read`;

const metaImage = new URL(`/og/posts/${post.id}.png`, Astro.site).toString();

const { Content } = await render(post);
---

<BaseLayout
  pageTitle={`${post.data.title} — Zach Callahan`}
  metaDescription={post.data.description}
  tags={post.data.tags}
  {metaImage}
  ogType="article"
  publishedTime={toIsoTimestamp(post.data.date)}
  showProgress
>
  <div class="panel-wrap">
    <article class="panel post" id="post">
      <div class="post-inner">
        <a class="crumb mono" href="/posts">← All Transmissions</a>

        <div class="post-head">
          <span class="mono eyebrow">{eyebrow}</span>
          <h1>{post.data.title}</h1>
          <div class="post-meta">
            <span class="mono">{longDate}</span>
            <span class="mono">{readTime}</span>
            <div class="tags">
              {
                post.data.tags.map((tag) => (
                  <a class="tag" href={`/posts/by-tag/${tag}`}>
                    {tag}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <div class="post-body">
          <Content />
        </div>

        <p class="end-mark mono">▣ End of Transmission</p>
      </div>
    </article>

    {
      (prev || next) && (
        <div class="post-nav">
          {prev && (
            <a class="panel prev" href={`/posts/${prev.id}`}>
              <span class="dir mono">← Previous</span>
              <h3>{prev.data.title}</h3>
            </a>
          )}
          {next && (
            <a class="panel next" href={`/posts/${next.id}`}>
              <span class="dir mono">Next →</span>
              <h3>{next.data.title}</h3>
            </a>
          )}
        </div>
      )
    }
  </div>
</BaseLayout>

<style is:global>
  main {
    padding-top: calc(var(--nav-h) + 4.125rem); /* = 8.5rem */
  }

  /* ---------- article ---------- */
  .post {
    padding: 4rem 0 3.5rem;
    font-size: 17px;
    line-height: 1.75;
  }
  .post-inner {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .crumb {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 2.6rem;
    transition: color 0.3s;
  }
  .crumb:hover {
    color: var(--brass);
  }

  .post-head .eyebrow {
    color: var(--brass);
    letter-spacing: 0.3em;
    display: block;
    margin-bottom: 1.3rem;
  }
  .post-head h1 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: clamp(1.9rem, 4.4vw, 3rem);
    letter-spacing: 0.06em;
    line-height: 1.22;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 2rem;
    align-items: baseline;
    margin-top: 1.6rem;
    padding-bottom: 2.2rem;
    background: var(--brass-rule) center bottom / 100% 1px no-repeat;
  }
  .post-meta .tags {
    display: flex;
    gap: 0.45rem;
    margin-left: auto;
  }
  .post-meta .tags a.tag {
    text-decoration: none;
  }
  .post-meta .tags a.tag:hover {
    border-color: var(--celest);
  }

  .post-body {
    padding-top: 2.4rem;
  }
  .post-body p {
    margin-bottom: 1.5rem;
  }
  .post-body > p:first-of-type::first-letter {
    font-family: "Marcellus", serif;
    font-size: 3.4em;
    line-height: 0.85;
    float: left;
    padding: 0.08em 0.12em 0 0;
    color: var(--brass);
  }
  /* links rest bare — brass alone marks them — and the rail returns on
     hover; transparent (not none) keeps the layout stable */
  .post-body a {
    color: var(--brass);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s;
  }
  .post-body a:hover {
    border-color: var(--brass);
  }
  /* external destinations wear a departure glyph — rehype-external-links
     stamps target="_blank" on every absolute URL. The doubled content
     declaration is the alt-text syntax: supporting browsers keep the
     glyph out of the accessible name, older ones fall back to plain. */
  .post-body a[target="_blank"]::after {
    content: "↗";
    content: "↗" / "";
    font-size: 0.7em;
    margin-left: 0.18em;
    vertical-align: 0.18em;
  }
  .post-body h2 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    margin: 3rem 0 1.2rem;
    padding-top: 2.2rem;
    background: var(--brass-rule) center top / 100% 1px no-repeat;
  }
  /* A post that opens with a heading otherwise stacks the meta rule and
     the heading's own top rule around an empty band. */
  .post-body > h2:first-child {
    margin-top: 0;
    padding-top: 0;
    background: none;
  }
  /* markdown thematic breaks (---): no post uses one yet, but the default
     bevelled hr would land far off-language if one ever does */
  .post-body hr {
    border: none;
    height: 1px;
    background: var(--brass-rule) center / 100% 1px no-repeat;
    margin: 3rem 0;
  }
  .post-body h3 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.15rem;
    letter-spacing: 0.08em;
    margin: 2.2rem 0 0.9rem;
  }
  .post-body h4 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    margin: 1.8rem 0 0.7rem;
  }
  .post-body h5 {
    font-family: "Marcellus", serif;
    font-weight: 400;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    margin: 1.5rem 0 0.6rem;
  }
  /* the scale terminates in chart furniture rather than an ever-smaller
     serif — h6 takes the eyebrow voice so it can't be mistaken for h5 */
  .post-body h6 {
    font-family: "Spline Sans Mono", monospace;
    font-weight: 400;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--brass);
    margin: 1.5rem 0 0.6rem;
  }
  /* the smaller headings also take a bronze cast — brass tempered with
     ink — warming to full brass under the cursor, the way links do */
  .post-body h3,
  .post-body h4,
  .post-body h5 {
    color: color-mix(in srgb, var(--brass) 60%, var(--ink));
    transition: color 0.3s;
  }
  .post-body h3:hover,
  .post-body h4:hover,
  .post-body h5:hover {
    color: var(--brass);
  }
  /* below the h2 rule the hierarchy runs on comets: each smaller heading
     trails off to the right in a brass star whose right ray stretches
     into a tail that runs out the rest of the line — the fade arrives
     sooner as the headings sink. A heading that wraps sends its comet
     to a full-width row of its own; one whose last line crowds the
     margin does the same once less than the tail's minimum remains. */
  .post-body h3,
  .post-body h4,
  .post-body h5 {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: 0.75rem;
  }
  .post-body h3::after,
  .post-body h4::after,
  .post-body h5::after {
    content: "";
    flex: 1;
    min-width: 4rem;
    height: 7px;
    clip-path: polygon(
      3.5px 0,
      4.4px 2.6px,
      100% 3px,
      100% 4px,
      4.4px 4.4px,
      3.5px 7px,
      2.6px 4.4px,
      0 3.5px,
      2.6px 2.6px
    );
  }
  .post-body h3::after {
    background: linear-gradient(
      90deg,
      var(--brass),
      var(--brass-dim) 14px,
      transparent
    );
  }
  .post-body h4::after {
    background: linear-gradient(
      90deg,
      var(--brass),
      var(--brass-dim) 14px,
      transparent 62%
    );
  }
  .post-body h5::after {
    background: linear-gradient(
      90deg,
      var(--brass),
      var(--brass-dim) 14px,
      transparent 35%
    );
  }
  /* rehype-autolink-headings wraps heading text in an anchor link;
     keep it visually indistinguishable from plain heading text. */
  .post-body h2 a.anchor,
  .post-body h3 a.anchor,
  .post-body h4 a.anchor,
  .post-body h5 a.anchor,
  .post-body h6 a.anchor {
    color: inherit;
    text-decoration: none;
    border-bottom: none;
  }
  .post-body h2 a.anchor:hover,
  .post-body h3 a.anchor:hover,
  .post-body h4 a.anchor:hover,
  .post-body h5 a.anchor:hover,
  .post-body h6 a.anchor:hover {
    border-bottom: none;
  }
  .post-body ul,
  .post-body ol {
    margin: 0 0 1.5rem 1.2rem;
  }
  .post-body ol {
    margin-left: 1.4rem;
  }
  /* a nested list's bottom margin belongs to the list that closes the
     block, not mid-item — without this, inner lists open phantom gaps */
  .post-body li > ul,
  .post-body li > ol {
    margin-bottom: 0;
  }
  .post-body li {
    margin-bottom: 0.5rem;
  }
  .post-body li::marker {
    color: var(--brass);
  }
  /* GFM task lists: the checkbox is the marker — suppress the bullet,
     keep the text on the list's text edge, and hang the box in the
     gutter so wrapped lines align under the first */
  .post-body li.task-list-item {
    list-style: none;
    margin-left: -1.2rem;
    padding-left: 1.55rem;
  }
  /* the native control is disabled (GFM emits it so) and browsers dim it
     past recognition — draw our own: a square chart-frame, filled with a
     brass body when checked */
  .post-body li.task-list-item input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 0.85em;
    height: 0.85em;
    margin: 0 0.7em 0 -1.55em;
    border: 1px solid var(--brass-dim);
    border-radius: 3px;
    vertical-align: -0.05em;
  }
  .post-body li.task-list-item input[type="checkbox"]:checked {
    background: radial-gradient(
      circle,
      var(--brass) 0 38%,
      transparent 45%
    );
  }
  .post-body blockquote {
    margin: 2.2rem 0;
    padding: 0.4rem 0 0.4rem 1.6rem;
    border-left: 1px solid var(--brass);
    font-style: italic;
    color: var(--ink-dim);
  }
  /* the quote's own padding closes the block; a trailing paragraph or
     list must not pad it further */
  .post-body blockquote > :last-child {
    margin-bottom: 0;
  }
  /* GFM alerts (rehype-github-alerts, custom aside build): chart
     marginalia, not quotations — body copy stays upright and full-ink,
     the type announces itself in the eyebrow voice, and each type keeps
     the quote's hairline rail but in its own hue over a faint wash */
  .post-body .markdown-alert {
    --alert-hue: var(--celest);
    margin: 2.2rem 0;
    padding: 1rem 1.6rem;
    border-left: 1px solid var(--alert-hue);
    border-radius: 0 10px 10px 0;
    background: color-mix(in srgb, var(--alert-hue) 7%, transparent);
  }
  .post-body .markdown-alert > :last-child {
    margin-bottom: 0;
  }
  .post-body .markdown-alert-title {
    font-family: "Spline Sans Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--alert-hue);
    margin-bottom: 0.7rem;
  }
  /* the glyph escalates with the stakes: open diamond → filled diamond
     for notice, guiding star for tips, open triangle → filled triangle
     (the chart's hazard mark) for danger. Doubled content declaration is
     the alt-text syntax, kin to the departure glyph above. */
  .post-body .markdown-alert-title::before {
    content: var(--alert-glyph) "  ";
    content: var(--alert-glyph) "  " / "";
  }
  .post-body .markdown-alert-note {
    --alert-glyph: "◇";
  }
  .post-body .markdown-alert-tip {
    --alert-hue: var(--verdigris);
    --alert-glyph: "✦";
  }
  .post-body .markdown-alert-important {
    --alert-hue: var(--heliotrope);
    --alert-glyph: "◆";
  }
  .post-body .markdown-alert-warning {
    --alert-hue: var(--brass);
    --alert-glyph: "△";
  }
  .post-body .markdown-alert-caution {
    --alert-hue: var(--cinnabar);
    --alert-glyph: "▲";
  }
  /* Diagram plates (build-time mermaid, src/lib/diagrams): a figure in
     the chart voice. Eyebrow strip and scroller paint their own halves
     the way the code-frame's header and pre do — same glass, same
     hairline, no clipping wrapper. */
  .post-body .diagram-plate {
    margin: 2.2rem 0;
    /* One column, two rows — eyebrow band over scroller. The grid lets
       the edge fades and the action pill ride the rows' rendered
       heights, so a wrapping title needs no measuring. The plate joins
       the code-frame's expand system (rehype-frames puts the button in
       the eyebrow): explicit width so expand/collapse can transition;
       the svg's scale-with-a-floor rule turns the extra width into type
       size rather than empty margin. */
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    width: 100%;
    transition:
      width 0.35s ease,
      margin 0.35s ease;
  }
  /* explicit rows — pseudo grid items would otherwise auto-place */
  .post-body .diagram-plate > .diagram-eyebrow {
    grid-area: 1 / 1;
  }
  .post-body .diagram-plate > .diagram-scroll {
    grid-area: 2 / 1;
    min-width: 0;
  }
  .post-body .diagram-plate:has(.expand-toggle:checked) {
    --code-expanded: max(100%, min(var(--max), 100vw - 4rem) - 4rem);
    width: var(--code-expanded);
    margin-inline: calc((100% - var(--code-expanded)) / 2);
  }
  @media (prefers-reduced-motion: reduce) {
    .post-body .diagram-plate {
      transition: none;
    }
  }
  /* The actions are a figcaption sibling (so button labels never join
     the caption's text) overlaid on the eyebrow band — same grid cell,
     centred in whatever height the wrapping title renders, holding the
     code-head's edge inset. The edge fades live with the code-frame's,
     below. */
  .post-body .diagram-plate > .code-actions {
    grid-area: 1 / 1;
    justify-self: end;
    align-self: center;
    padding-right: 0.6rem;
    z-index: 1;
  }
  .post-body .diagram-eyebrow {
    display: flex;
    align-items: baseline;
    gap: 0.9em;
    padding: 0.8rem 1.6rem;
    background: var(--code-bg);
    border: 1px solid var(--glass-hair);
    border-radius: 10px 10px 0 0;
    font-family: "Spline Sans Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }
  /* chart-key furniture, kin to the code-frame's language tag; the
     numeral never breaks across lines — the title does the wrapping */
  .post-body .diagram-fig-no {
    color: var(--brass);
    white-space: nowrap;
  }
  .post-body .diagram-fig-title {
    color: var(--ink-dim);
  }
  .post-body .diagram-fig-title::before {
    content: "— ";
    content: "— " / "";
  }
  .post-body .diagram-scroll {
    overflow-x: auto;
    padding: 1.6rem;
    background: var(--code-bg);
    border: 1px solid var(--glass-hair);
    border-top: none;
    border-radius: 0 0 10px 10px;
    scrollbar-width: thin;
    scrollbar-color: var(--brass-dim) transparent;
  }
  .post-body .diagram-scroll::-webkit-scrollbar {
    height: 8px;
  }
  .post-body .diagram-scroll::-webkit-scrollbar-thumb {
    background: var(--brass-dim);
    border-radius: 4px;
  }
  /* Scale-with-a-floor: never above intrinsic size (--w, set by the
     build), shrink with the column until the type would drop below
     three-quarters scale — legibility lives in the text, so the floor
     is a fraction of intrinsic, not an absolute width — then hold and
     let the plate scroll like a wide table. Centred when it has room
     to spare; width/height attrs give height:auto its ratio. */
  .post-body .diagram-plate svg {
    display: block;
    width: min(var(--w), 100%);
    height: auto;
    min-width: calc(var(--w) * 0.75);
    margin-inline: auto;
  }
  /* Every table ships framed (rehype-frames): the .table-scroll wrapper
     does the scrolling, so the table stays a real table — layout intact,
     row rules spanning full width — and never narrower than the frame. */
  .post-body table {
    border-collapse: collapse;
    min-width: 100%;
    margin: 0;
  }
  /* rehype-frames wraps each table in a .table-scroll inside a
     code-frame — header strip, expand affordance, and clip fade shared
     with code blocks. The scroller paints the frame's lower half the
     way the framed pre does. */
  .post-body .table-scroll {
    overflow-x: auto;
    padding: 0.4rem 1.6rem 0.9rem;
    background: var(--code-bg);
    border: 1px solid var(--glass-hair);
    border-top: none;
    border-radius: 0 0 10px 10px;
    scrollbar-width: thin;
    scrollbar-color: var(--brass-dim) transparent;
  }
  .post-body .table-scroll::-webkit-scrollbar {
    height: 8px;
  }
  .post-body .table-scroll::-webkit-scrollbar-thumb {
    background: var(--brass-dim);
    border-radius: 4px;
  }
  /* the frame's glass edge closes the composition; a final hairline
     right above it would read as a double rule */
  .post-body .table-scroll tr:last-child td {
    border-bottom: none;
  }
  .post-body th {
    font-family: "Spline Sans Mono", monospace;
    font-weight: 400;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--brass);
    border-bottom: 1px solid var(--brass-dim);
  }
  .post-body th,
  .post-body td {
    padding: 0.55rem 1.4rem 0.55rem 0;
  }
  .post-body th:last-child,
  .post-body td:last-child {
    padding-right: 0;
  }
  .post-body td {
    border-bottom: 1px solid var(--hair);
  }
  /* identifiers in cells stay whole — the table scrolls, so the inline
     pill's break-anywhere escape hatch would only shatter them */
  .post-body th code,
  .post-body td code {
    overflow-wrap: normal;
    white-space: nowrap;
  }
  .post-body code {
    font-family: "Spline Sans Mono", monospace;
    font-size: 0.86em;
    background: var(--code-bg);
    border: 1px solid var(--hair);
    border-radius: 5px;
    padding: 0.1em 0.4em;
    /* long identifiers in headings/prose must never pan the page sideways;
       when one must break, clone gives each fragment a complete pill
       instead of shearing the border mid-word */
    overflow-wrap: anywhere;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }
  /* rehype-frames wraps each pre in a .code-frame with a header strip —
     language hint left, expand/copy buttons right — as a sibling (children
     of the pre pollute the code's accessible text), so the frame is the
     no-JS rendering too; only the buttons wait for JS. The frame is
     deliberately chrome-free: header and pre each paint their own half of
     the block (two plain boxes, no clip), because a rounded overflow-clip
     wrapper inside the backdrop-filtered panel breaks the panel's blur in
     some compositors. Same grid as the diagram plate, so the edge fades
     ride the scroller row. Width is explicit so expand/collapse can
     transition. */
  .post-body .code-frame {
    --code-head-h: 2.4rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    margin: 2rem 0;
    width: 100%;
    transition:
      width 0.35s ease,
      margin 0.35s ease;
  }
  .post-body .code-frame > .code-head {
    grid-area: 1 / 1;
  }
  .post-body .code-frame > pre,
  .post-body .code-frame > .table-scroll {
    grid-area: 2 / 1;
    min-width: 0;
  }
  .post-body .code-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--code-head-h);
    /* lang sits on the code's left rhythm; buttons keep their edge inset */
    padding: 0 0.6rem 0 1.6rem;
    background: var(--code-bg);
    border: 1px solid var(--glass-hair);
    border-radius: 10px 10px 0 0;
  }
  /* chart-key furniture, kin to the resume legend's KEY tag */
  .post-body .code-lang {
    color: var(--brass);
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }
  /* Expanded: break out of the prose measure to the panel's inner width
     (derived from the same tokens the panel uses, since no ancestor exposes
     it), less a 2rem inset each side. Equal negative margins keep the frame
     centred on the panel; max() pins it to the measure when the viewport
     affords nothing extra. */
  .post-body .code-frame:has(.expand-toggle:checked) {
    --code-expanded: max(100%, min(var(--max), 100vw - 4rem) - 4rem);
    width: var(--code-expanded);
    margin-inline: calc((100% - var(--code-expanded)) / 2);
  }
  @media (prefers-reduced-motion: reduce) {
    .post-body .code-frame {
      transition: none;
    }
  }
  .post-body .code-frame pre {
    margin: 0;
    border-top: none;
    border-radius: 0 0 10px 10px;
  }
  /* Edge fades while content continues past a clip edge, driven by the
     scroller's own scroll timeline — no listeners. Underlying opacity is
     0 and the fill-both animations only apply while the timeline is
     active (the scroller genuinely overflows), so a fitting block shows
     nothing, and engines without timelines never see a stuck gradient.
     Two gradient layers because --code-bg is translucent glass — --bg
     underneath lands the fade on the block's true composite color. Grid
     items pinned to the scroller row; the 1px margin tucks them inside
     the glass border. */
  .post-body .code-frame::before,
  .post-body .code-frame::after,
  .post-body .diagram-plate::before,
